        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesExited == null || vars.caseManagerDecisions.stagesExited.length == 0 || !vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == 'Document Intake' || stage.stageName == 'Document Verification' || stage.stageName == 'Party Validation' || stage.stageName == 'Port Readiness' || stage.stageName == 'Released' || stage.stageName == 'Party Review' || stage.stageName == 'Port Review' || stage.stageName == 'Rejected')) &amp;&amp; (vars.caseManagerDecisions.stagesCompleted == null || vars.caseManagerDecisions.stagesCompleted.length == 0 || !vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == 'Document Intake' || stage.stageName == 'Document Verification' || stage.stageName == 'Party Validation' || stage.stageName == 'Port Readiness' || stage.stageName == 'Released' || stage.stageName == 'Party Review' || stage.stageName == 'Port Review' || stage.stageName == 'Rejected'))</bpmn:conditionExpression>
