      <bpmn:task id="TasksEventSubProcessVariablesSetupNode" name="Set initial state variables for tasks event subprocess">
        <bpmn:extensionElements>
          <uipath:mapping version="v1">
            <uipath:type value="BPMN.Variables" version="v1" />
            <uipath:output name="tasksCompletedEvent" type="string" source="=js:`CM:tasksCompleted:${((vars.tasksEventSubprocessResponse.incitingEventId != null &#38;&#38; vars.tasksEventSubprocessResponse.incitingEventId.length &#62; 0) ? vars.tasksEventSubprocessResponse.incitingEventId : (vars.tasksEventSubprocessResponse.incitingEvent ?? &#34;&#34;))}:${vars.tasksEventSubprocessResponse.taskName ?? &#34;&#34;}`" var="tasksCompletedEventVariable" custom="true" internal="true" />
            <uipath:output name="tasksRunningEvent" type="string" source="=js:`CM:tasksRunning:${((vars.tasksEventSubprocessResponse.incitingEventId != null &#38;&#38; vars.tasksEventSubprocessResponse.incitingEventId.length &#62; 0) ? vars.tasksEventSubprocessResponse.incitingEventId : (vars.tasksEventSubprocessResponse.incitingEvent ?? &#34;&#34;))}:${vars.tasksEventSubprocessResponse.taskName ?? &#34;&#34;}`" var="tasksRunningEventVariable" custom="true" internal="true" />
            <uipath:output name="taskCompletedOutputs" type="json" var="taskCompletedOutputsVariable" custom="true" internal="true"><![CDATA[=js:({})]]></uipath:output>
            <uipath:output name="tasksEventSubprocessLocalLastTaskCompleted" type="string" var="tasksSubprocessLocalLastTaskCompletedVariable" custom="true" internal="true"><![CDATA[=js:""]]></uipath:output>
            <uipath:output name="connectorResponse" type="json" var="connectorResponse" custom="true" internal="true"><![CDATA[=js:(vars.tasksEventSubprocessResponse.connectorResponse ?? {})]]></uipath:output>
            <uipath:output name="eventMetadata" type="json" var="eventMetadata" custom="true" internal="true"><![CDATA[=js:(vars.tasksEventSubprocessResponse.eventMetadata ?? {})]]></uipath:output>
          </uipath:mapping>
        </bpmn:extensionElements>
        <bpmn:incoming>edge_TasksEventSubProcessStartEventNode-TasksEventSubProcessVariablesSetupNode</bpmn:incoming>
        <bpmn:outgoing>edge_TasksEventSubProcessVariablesSetupNode-TasksEventSubProcessOverlayMessageVarsNode</bpmn:outgoing>
      </bpmn:task>
